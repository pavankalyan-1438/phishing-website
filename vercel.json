{
  "buildCommand": "cd fishgitam-main && npm install && npm run build",
  "outputDirectory": "fishgitam-main/dist",
  "installCommand": "echo \"Install skipped in root\"",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
